@page "/checkout"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using BlazorSampleCommerce.DTOs
@inject CartService CartService
@inject AuthService AuthService
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Checkout — Archetipo</PageTitle>

@if (!AuthService.IsLoggedIn)
{
    NavManager.NavigateTo("/carrello");
    return;
}

@if (orderCompleted)
{
    <div class="cart-page" style="text-align:center;padding-top:6rem">
        <p class="text-fell" style="font-size:2rem;margin-bottom:1rem">Ordine ricevuto.</p>
        <p class="text-caps" style="opacity:0.45;margin-bottom:2.5rem">La tua scelta è stata registrata.</p>
        <a href="/" class="btn-acquire">Torna alla collezione <span class="arrow">→</span></a>
    </div>
    return;
}

<div class="cart-page">
    <h1 class="cart-title">Riepilogo ordine</h1>

    <!-- prodotti nel carrello -->
    <div class="checkout-summary">
        @foreach (var item in CartService.Items)
        {
            <div class="cart-item">
                <div class="cart-item-info">
                    <span class="cart-item-name">@item.ProductName</span>
                    @if (!string.IsNullOrEmpty(item.SkuLabel))
                    {
                        <span class="cart-item-sku">@item.SkuLabel</span>
                    }
                </div>
                <div style="font-family:var(--font-sans);font-size:0.85rem;opacity:0.6">x@item.Quantity</div>
                <div class="cart-item-price">€ @item.Subtotal.ToString("0.00")</div>
            </div>
        }
        <div class="cart-footer" style="margin-top:1.5rem">
            <div class="cart-total">
                <span class="text-caps" style="opacity:0.5">Totale</span>
                <span class="cart-total-price">€ @CartService.Total.ToString("0.00")</span>
            </div>
        </div>
    </div>

    <!-- scelta indirizzo -->
    <div style="margin-top:3rem">
        <p class="text-caps" style="opacity:0.45;margin-bottom:1.5rem">Indirizzo di spedizione</p>

        @if (isLoadingAddresses)
        {
            <p style="font-family:var(--font-sans);font-size:0.85rem;opacity:0.45">Caricamento indirizzi…</p>
        }
        else if (addresses.Any())
        {
            @foreach (var addr in addresses)
            {
                <div class="address-card @(selectedAddressId == addr.Id ? "selected" : "")"
                     @onclick="() => selectedAddressId = addr.Id">
                    <div class="address-card-name">@addr.Receiver</div>
                    <div class="address-card-line">@addr.StreetAdress @addr.ComplementAddress</div>
                    <div class="address-card-line">@addr.ZipCode @addr.City (@addr.Province) — @addr.Country</div>
                    @if (addr.IsPreferred)
                    {
                        <span class="text-caps" style="font-size:0.65rem;opacity:0.45;margin-top:0.25rem;display:block">preferito</span>
                    }
                </div>
            }
        }
        else
        {
            <p style="font-family:var(--font-sans);font-size:0.85rem;opacity:0.55;margin-bottom:1rem">
                Non hai ancora indirizzi salvati. Aggiungine uno dal tuo <a href="/profile" style="text-decoration:underline">profilo</a>.
            </p>
        }
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="modal-error" style="margin-top:1.5rem">@errorMessage</div>
    }

    <div class="cart-actions" style="margin-top:3rem">
        <a href="/carrello" class="detail-back-link">← Modifica carrello</a>

        <button class="btn-acquire" @onclick="ConfirmOrder"
                disabled="@(isOrdering || selectedAddressId == 0 || !CartService.Items.Any())">
            @if (isOrdering)
            {
                <span>…</span>
            }
            else
            {
                <span>Conferma ordine</span>
                <span class="arrow">→</span>
            }
        </button>
    </div>
</div>

@code {
    private List<AddressDto> addresses = new();
    private int selectedAddressId = 0;
    private bool isLoadingAddresses = true;
    private bool isOrdering = false;
    private bool orderCompleted = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn) return;

        try
        {
            var result = await Http.GetFromJsonAsync<List<AddressDto>>($"Address/user/{AuthService.CurrentUser!.Id}");
            addresses = result ?? new();

            // preseleziono l'indirizzo preferito se esiste
            var preferred = addresses.FirstOrDefault(a => a.IsPreferred);
            if (preferred is not null)
                selectedAddressId = preferred.Id;
            else if (addresses.Any())
                selectedAddressId = addresses.First().Id;
        }
        catch { addresses = new(); }
        finally { isLoadingAddresses = false; }
    }

    private async Task ConfirmOrder()
    {
        errorMessage = "";
        if (selectedAddressId == 0)
        {
            errorMessage = "Seleziona un indirizzo di spedizione.";
            return;
        }

        isOrdering = true;
        try
        {
            var dto = new OrderCreateDto
            {
                UserId    = AuthService.CurrentUser!.Id,
                AddressId = selectedAddressId,
                Items     = CartService.Items.Select(i => new OrderItemCreateDto
                {
                    SkuId    = i.SkuId,
                    Quantity = i.Quantity
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("Orders", dto);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Qualcosa è andato storto. Riprova.";
                return;
            }

            await CartService.ClearAsync();
            orderCompleted = true;
        }
        catch
        {
            errorMessage = "Errore di connessione. Controlla che il server sia attivo.";
        }
        finally
        {
            isOrdering = false;
        }
    }
}
