<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=IM+Fell+English:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet" />

    <!-- Tailwind Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                fontFamily: {
                    display: ['"Cormorant Garamond"', 'Georgia', 'serif'],
                    fell:    ['"IM Fell English"', 'Georgia', 'serif'],
                    sans:    ['"DM Sans"', 'system-ui', 'sans-serif'],
                },
                extend: {
                    colors: {
                        espresso:  '#0d0906',
                        bark:      '#1a0f08',
                        leather:   '#3d2414',
                        walnut:    '#6b3f1e',
                        sand:      '#c9a07a',
                        cream:     '#e8d9c4',
                        ivory:     '#f2ece0',
                        parchment: '#f8f4ec',
                    },
                }
            }
        }
    </script>

    <!-- Bootstrap base (per pagine funzionali: register, profilo, ecc.) -->
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <!-- Archetipo design system — sovrascrive Bootstrap dove serve -->
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BlazorSampleCommerce.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <!-- Film grain overlay -->
    <div class="grain-layer" aria-hidden="true"></div>

    <Routes />
    <ReconnectModal />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/lenis@1.1.14/dist/lenis.min.js"></script>
    <script src="js/archetipo.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
