@page "/profile"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject HttpClient Http
@inject NavigationManager NavManager
@using BlazorSampleCommerce.DTOs

<PageTitle>Modifica Profilo</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="bi bi-person-gear"></i> Modifica Profilo</h3>
                </div>
                <div class="card-body">
                    
                    @if (isLoading)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p>Caricamento dati utente...</p>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="userModel" OnValidSubmit="HandleUpdate">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label">Nome Completo</label>
                                <InputText class="form-control" @bind-Value="userModel.Name" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <InputText class="form-control" @bind-Value="userModel.Email" />
                            </div>

                            <div class="form-check form-switch mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="userModel.Seller" id="sellerCheck" />
                                <label class="form-check-label" for="sellerCheck">Sei un venditore?</label>
                            </div>

                            @if (userModel.Seller)
                            {
                                <div class="row border rounded p-3 bg-light mb-3">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Partita IVA</label>
                                        <InputText class="form-control" @bind-Value="userModel.Iva" />
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Nome Azienda</label>
                                        <InputText class="form-control" @bind-Value="userModel.TradingName" />
                                    </div>
                                </div>
                            }

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                        <span> Salvataggio...</span>
                                    }
                                    else
                                    {
                                        <span>Aggiorna Profilo</span>
                                    }
                                </button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">Annulla</button>
                            </div>
                        </EditForm>
                    }

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert @statusClass mt-3">@statusMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Guid? userId => AuthService.CurrentUser?.Id ?? Guid.Empty;
    private UserUpdateDto userModel = new();
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string statusMessage = "";
    private string statusClass = "";
    private bool canShow = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserData();
    }

    private async Task LoadUserData()
    {
        try
        {
            isLoading = true;
            var data = await Http.GetFromJsonAsync<UserUpdateDto>($"User/{userId}");
            if (data != null) userModel = data;
        }
        catch (Exception ex)
        {
            statusMessage = "Errore nel caricamento dei dati.";
            statusClass = "alert-danger";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdate()
    {
        if (userId == Guid.Empty) return;
        isSubmitting = true;
        statusMessage = "";

        try
        {
            var response = await Http.PutAsJsonAsync($"User/{userId}", userModel);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Profilo aggiornato con successo!";
                statusClass = "alert-success";
                //In order to update name in nav if it was changed
                if (AuthService.CurrentUser != null)
                {
                    AuthService.CurrentUser.Name = userModel.Name;
                    AuthService.CurrentUser.Email = userModel.Email;
                }
            }
            else
            {
                statusMessage = $"Errore API: {response.StatusCode}";
                statusClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Errore di connessione: {ex.Message}";
            statusClass = "alert-danger";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack() => NavManager.NavigateTo("/");
}