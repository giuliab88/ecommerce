@page "/my-products"
@rendermode InteractiveServer
@using BlazorSampleCommerce.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager
@inject Services.AuthService AuthService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>I miei prodotti</h2>
        <a href="/product-form" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Aggiungi prodotto
        </a>
    </div>

    @if (myProducts == null)
    {
        <div class="text-center"><div class="spinner-border"></div></div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var prod in myProducts)
            {
                <div class="col-md-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@prod.Name</h5>
                            <p class="text-muted small">Brand: @prod.Brand</p>
                            <p class="card-text text-truncate">@prod.Description</p>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <button class="btn btn-outline-warning w-100" @onclick="() => EditProduct(prod.Id)">
                                <i class="bi bi-pencil"></i> Modifica
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProductDto>? myProducts;
    private Guid? SellerId => AuthService.CurrentUser?.Id;

    protected override async Task OnInitializedAsync()
    {
        var all = await Http.GetFromJsonAsync<List<ProductDto>>("Products");
        if (SellerId.HasValue)
        {
            myProducts = all?.Where(p => p.SellerId == SellerId.Value).ToList();
        }
    }

    private void EditProduct(Guid id) => NavManager.NavigateTo($"/product-form/{id}");
}