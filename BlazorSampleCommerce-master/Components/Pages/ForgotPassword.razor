@page "/recupera-password"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Recupera password — Archetipo</PageTitle>

<div class="register-wrap">

    <div class="register-left">
        <div class="register-left-inner">
            <a href="/" class="detail-back-link">← torna al catalogo</a>
            <div class="register-heading">
                <div class="detail-emotion-label">accesso</div>
                <h1 class="register-title">Recupera<br />il tuo<br />spazio</h1>
                <p class="register-subtitle">ti mandiamo un link<br />per reimpostare la password</p>
            </div>
        </div>
    </div>

    <div class="register-right">
        <div class="register-form-wrap">

            @if (sent)
            {
                <div style="text-align:center;padding:2rem 0">
                    <div class="detail-emotion-label" style="margin-bottom:1.2rem">inviato</div>
                    <p style="font-family:var(--font-fell);font-style:italic;font-size:1.1rem;color:var(--leather);line-height:1.9;opacity:0.8">
                        Se l'email è registrata,<br />riceverai un link a breve.
                    </p>
                    <p style="font-family:var(--font-sans);font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--sand);opacity:0.65;margin-top:1.5rem">
                        Controlla anche la cartella spam.
                    </p>
                    <a href="/" class="detail-back-link" style="display:inline-block;margin-top:2rem">← torna alla collezione</a>
                </div>
            }
            else
            {
                <div class="register-field">
                    <label class="review-form-label">La tua email</label>
                    <input type="email" class="modal-input" @bind="email" placeholder="mario@esempio.it" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="modal-error" style="margin-bottom:1rem">@errorMessage</div>
                }

                <button class="btn-acquire" style="width:100%;justify-content:center;margin-top:0.5rem"
                        @onclick="HandleSubmit" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>…</span>
                    }
                    else
                    {
                        <span>Invia link</span>
                        <span class="arrow">→</span>
                    }
                </button>

                <p class="register-login-hint">
                    Ricordi la password?
                    <button class="register-link-btn" @onclick='() => NavManager.NavigateTo("/")'>Accedi</button>
                </p>
            }

        </div>
    </div>

</div>

@code {
    private string email = "";
    private string errorMessage = "";
    private bool isSubmitting = false;
    private bool sent = false;

    private async Task HandleSubmit()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Inserisci la tua email.";
            return;
        }

        isSubmitting = true;
        try
        {
            await Http.PostAsJsonAsync("Auth/forgot-password", new { Email = email });
            sent = true;
        }
        catch
        {
            errorMessage = "Errore di connessione. Riprova.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
