@page "/reimposta-password"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Nuova password — Archetipo</PageTitle>

<div class="register-wrap">

    <div class="register-left">
        <div class="register-left-inner">
            <a href="/" class="detail-back-link">← torna al catalogo</a>
            <div class="register-heading">
                <div class="detail-emotion-label">sicurezza</div>
                <h1 class="register-title">Nuova<br />password</h1>
                <p class="register-subtitle">scegli qualcosa<br />che ricorderai</p>
            </div>
        </div>
    </div>

    <div class="register-right">
        <div class="register-form-wrap">

            @if (string.IsNullOrEmpty(token))
            {
                <div style="text-align:center;padding:2rem 0">
                    <p style="font-family:var(--font-fell);font-style:italic;font-size:1.1rem;color:var(--leather);opacity:0.7">
                        Link non valido o mancante.
                    </p>
                    <a href="/recupera-password" class="detail-back-link" style="display:inline-block;margin-top:1.5rem">← Richiedi un nuovo link</a>
                </div>
            }
            else if (success)
            {
                <div style="text-align:center;padding:2rem 0">
                    <div class="detail-emotion-label" style="margin-bottom:1.2rem">fatto</div>
                    <p style="font-family:var(--font-fell);font-style:italic;font-size:1.1rem;color:var(--leather);line-height:1.9;opacity:0.8">
                        Password aggiornata.<br />Puoi accedere con le nuove credenziali.
                    </p>
                    <a href="/" class="detail-back-link" style="display:inline-block;margin-top:2rem">← torna alla collezione</a>
                </div>
            }
            else
            {
                <div class="register-field">
                    <label class="review-form-label">Nuova password</label>
                    <input type="password" class="modal-input" @bind="password" placeholder="••••••••" />
                </div>

                <div class="register-field">
                    <label class="review-form-label">Conferma password</label>
                    <input type="password" class="modal-input" @bind="confirmPassword" placeholder="••••••••" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="modal-error" style="margin-bottom:1rem">@errorMessage</div>
                }

                <button class="btn-acquire" style="width:100%;justify-content:center;margin-top:0.5rem"
                        @onclick="HandleSubmit" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>…</span>
                    }
                    else
                    {
                        <span>Aggiorna password</span>
                        <span class="arrow">→</span>
                    }
                </button>
            }

        </div>
    </div>

</div>

@code {
    [SupplyParameterFromQuery] public string? token { get; set; }

    private string password = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private bool isSubmitting = false;
    private bool success = false;

    private async Task HandleSubmit()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(password) || password.Length < 8)
        {
            errorMessage = "La password deve essere di almeno 8 caratteri.";
            return;
        }
        if (password != confirmPassword)
        {
            errorMessage = "Le password non coincidono.";
            return;
        }

        isSubmitting = true;
        try
        {
            var response = await Http.PostAsJsonAsync("Auth/reset-password", new
            {
                Token = token,
                NewPassword = password
            });

            if (response.IsSuccessStatusCode)
                success = true;
            else
                errorMessage = "Il link non è più valido. Richiedine uno nuovo.";
        }
        catch
        {
            errorMessage = "Errore di connessione. Riprova.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
